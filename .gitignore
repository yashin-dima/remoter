# Сборка
.build/
Remoter.app/
*.app/
DerivedData/
*.xcodeproj/
*.xcworkspace/

# Monaco: 13 МБ чужого минифицированного кода. Ставится одной командой и живёт вне репозитория —
# ./Scripts/vendor-monaco.sh (build.sh зовёт его сам, если Monaco не найден).
Web/vs/

# Ключи и сертификаты. Их здесь не должно быть НИКОГДА — ни для подписи, ни для тестов,
# ни «на минутку».
*.p12
*.pem
*.key
*.cer
id_rsa*
id_ed25519*

# Локальные данные и мусор системы
.DS_Store
*.swp
.env
.env.*

# Машинные настройки Claude Code. Приложение само пишет сюда хуки уведомлений при открытии
# проекта — в том числе когда открываешь как проект сам Remoter. Это НЕ часть репозитория:
# путь скрипта хука привязан к конкретной машине, а под тестами уводится в /tmp.
.claude/settings.local.json
